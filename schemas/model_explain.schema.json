{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "trade_date",
    "ts_code",
    "name",
    "ranking_score",
    "model_signal_summary",
    "cross_model_consistency",
    "model_logic_summary",
    "key_drivers",
    "facts",
    "inferences",
    "uncertainties",
    "evidence_ids",
    "evidence_insufficient"
  ],
  "properties": {
    "trade_date": {"type": "string"},
    "ts_code": {"type": "string"},
    "name": {"type": "string"},
    "ranking_score": {"type": "number", "description": "融合排序分，仅说明 TopK 来源，不用于归因解释"},
    "model_signal_summary": {
      "type": "array",
      "description": "各模型的独立分析摘要",
      "items": {
        "type": "object",
        "required": ["name", "horizon", "target", "score", "top_drivers", "signal_summary"],
        "properties": {
          "name": {"type": "string"},
          "horizon": {"type": "string"},
          "target": {"type": "string"},
          "weight": {"type": "number", "description": "可选，融合权重"},
          "score": {"type": "number", "description": "该模型原始分"},
          "top_drivers": {"type": "array", "items": {"type": "string"}, "description": "该模型主要驱动因子列表"},
          "signal_summary": {"type": "string", "description": "该模型的信号含义一句话总结"}
        }
      }
    },
    "cross_model_consistency": {"type": "string", "description": "多模型归因和得分方向一致性判断；如果只有一个模型，写明 single_model_only"},
    "model_logic_summary": {"type": "string"},
    "key_drivers": {"type": "array", "items": {"type": "string"}},
    "facts": {"type": "array", "items": {"type": "string"}},
    "inferences": {"type": "array", "items": {"type": "string"}},
    "uncertainties": {"type": "array", "items": {"type": "string"}},
    "evidence_ids": {"type": "array", "items": {"type": "string"}},
    "evidence_insufficient": {"type": "boolean"}
  },
  "additionalProperties": false
}
