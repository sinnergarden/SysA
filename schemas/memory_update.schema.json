{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "trade_date",
    "ts_code",
    "name",
    "should_update_company_memory",
    "should_update_industry_memory",
    "company_memory_patch",
    "industry_memory_patch",
    "summary",
    "facts",
    "inferences",
    "uncertainties",
    "evidence_ids",
    "evidence_insufficient"
  ],
  "properties": {
    "trade_date": {"type": "string"},
    "ts_code": {"type": "string"},
    "name": {"type": "string"},
    "should_update_company_memory": {"type": "boolean"},
    "should_update_industry_memory": {"type": "boolean"},
    "company_memory_patch": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["op", "target", "text", "reason", "evidence_ids"],
        "properties": {
          "op": {"enum": ["add", "update", "delete", "no_change"]},
          "target": {"enum": ["company", "industry"]},
          "text": {"type": "string"},
          "reason": {"type": "string"},
          "evidence_ids": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": false
      }
    },
    "industry_memory_patch": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["op", "target", "text", "reason", "evidence_ids"],
        "properties": {
          "op": {"enum": ["add", "update", "delete", "no_change"]},
          "target": {"enum": ["company", "industry"]},
          "text": {"type": "string"},
          "reason": {"type": "string"},
          "evidence_ids": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": false
      }
    },
    "summary": {"type": "string"},
    "facts": {"type": "array", "items": {"type": "string"}},
    "inferences": {"type": "array", "items": {"type": "string"}},
    "uncertainties": {"type": "array", "items": {"type": "string"}},
    "evidence_ids": {"type": "array", "items": {"type": "string"}},
    "evidence_insufficient": {"type": "boolean"}
  },
  "additionalProperties": false
}
