{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["trade_date", "universe_count", "stocks", "overall_status", "uncertainties"],
  "properties": {
    "trade_date": {"type": "string"},
    "universe_count": {"type": "integer"},
    "stocks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ts_code", "name", "industry", "data_available", "missing_data"],
        "properties": {
          "ts_code": {"type": "string"},
          "name": {"type": "string"},
          "industry": {"type": "string"},
          "data_available": {
            "type": "object",
            "required": ["sysq_signal", "financial", "news", "announcements", "company_memory", "industry_memory"],
            "additionalProperties": false,
            "properties": {
              "sysq_signal": {"type": "boolean"},
              "financial": {"type": "boolean"},
              "news": {"type": "boolean"},
              "announcements": {"type": "boolean"},
              "company_memory": {"type": "boolean"},
              "industry_memory": {"type": "boolean"}
            }
          },
          "missing_data": {"type": "array", "items": {"type": "string"}},
          "financial_brief": {"type": "string"},
          "news_brief": {"type": "string"},
          "announcements_brief": {"type": "string"}
        }
      }
    },
    "overall_status": {"enum": ["ready", "partial", "insufficient"]},
    "uncertainties": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
