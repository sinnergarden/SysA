{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "trade_date",
    "ts_code",
    "name",
    "catalyst_heat",
    "fundamental_catalysts",
    "sentiment_catalysts",
    "summary",
    "facts",
    "inferences",
    "uncertainties",
    "evidence_ids",
    "evidence_insufficient"
  ],
  "properties": {
    "trade_date": {"type": "string"},
    "ts_code": {"type": "string"},
    "name": {"type": "string"},
    "catalyst_heat": {"enum": ["cold", "warming", "hot", "overheated", "unknown"]},
    "fundamental_catalysts": {"type": "array", "items": {"type": "string"}},
    "sentiment_catalysts": {"type": "array", "items": {"type": "string"}},
    "summary": {"type": "string"},
    "facts": {"type": "array", "items": {"type": "string"}},
    "inferences": {"type": "array", "items": {"type": "string"}},
    "uncertainties": {"type": "array", "items": {"type": "string"}},
    "evidence_ids": {"type": "array", "items": {"type": "string"}},
    "evidence_insufficient": {"type": "boolean"}
  },
  "additionalProperties": false
}
